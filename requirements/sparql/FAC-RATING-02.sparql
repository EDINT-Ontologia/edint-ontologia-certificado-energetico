# FAC-RATING-02: Una calificación tiene exactamente una versión de escala (SKOS concept en RatingScaleVersions)

PREFIX edintcee: <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/>

SELECT ?rating (COUNT(?scale) AS ?scaleCount)
WHERE {
    ?rating a edintcee:EnergyRating .
    OPTIONAL { ?rating edintcee:ratingScaleVersion ?scale }
}
GROUP BY ?rating
HAVING (COUNT(?scale) != 1)
