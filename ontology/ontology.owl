    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyRating"/>
    <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
    <rdfs:comment xml:lang="es">Energía primaria no renovable. Se expresa como qudt:QuantityValue, típicamente en kWh/m²·año.</rdfs:comment>
    <rdfs:comment xml:lang="en">Non-renewable primary energy. Expressed as qudt:QuantityValue, typically in kWh/m²·year.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasRecommendation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
