  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/technicianPublicAuthorization">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
