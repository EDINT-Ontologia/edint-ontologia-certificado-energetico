    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="es">Mejoras en confort, salud o bienestar derivadas de la implementación (Art. 8.2.f).</rdfs:comment>
    <rdfs:comment xml:lang="en">Comfort, health or well-being improvements derived from implementation (Art. 8.2.f).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/primaryEnergyNonRenewable">
