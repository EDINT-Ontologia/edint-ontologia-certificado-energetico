  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/hasTechnicianAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="es">dirección del técnico</rdfs:label>
    <rdfs:label xml:lang="en">technician address</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CompetentTechnician"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal"/>
    <rdfs:comment xml:lang="es">Dirección postal del técnico competente. Se reutiliza esdir:DireccionPostal, que especializa schema:PostalAddress, vcard:Address y locn:Address, y permite representar vía, municipio, provincia y código postal con propiedades estándar (Anexo IV).</rdfs:comment>
    <rdfs:comment xml:lang="en">Postal address of the competent technician. Reuses esdir:DireccionPostal, which specialises schema:PostalAddress, vcard:Address and locn:Address, and allows representing street, municipality, province and postal code with standard properties (Annex IV).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n7601530229a9478b9243e345f887c1ccb55">
    <rdf:first rdf:nodeID="n7601530229a9478b9243e345f887c1ccb53"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="es">Dirección postal</rdfs:label>
    <rdfs:label xml:lang="en">Postal address</rdfs:label>
    <rdfs:comment xml:lang="es">Dirección postal en España. Especialización de schema:PostalAddress, vcard:Address y locn:Address. Permite representar una dirección con propiedades como schema:streetAddress, schema:addressLocality, schema:addressRegion y schema:postalCode.</rdfs:comment>
    <rdfs:comment xml:lang="en">Postal address in Spain. Specialisation of schema:PostalAddress, vcard:Address and locn:Address. Allows representing an address with properties like schema:streetAddress, schema:addressLocality, schema:addressRegion and schema:postalCode.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/heatingEfficiency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="es">rendimiento estacional calefacción</rdfs:label>
    <rdfs:label xml:lang="en">seasonal heating efficiency</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate"/>
    <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
    <rdfs:comment xml:lang="es">Rendimiento estacional del sistema de calefacción. Se expresa como qudt:QuantityValue.</rdfs:comment>
    <rdfs:comment xml:lang="en">Seasonal efficiency of the heating system. Expressed as qudt:QuantityValue.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/issuedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
