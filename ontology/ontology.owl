    <rdfs:label xml:lang="en">observed heritage protection</rdfs:label>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/EnergyCertificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:comment xml:lang="es">Si el edificio tiene protección patrimonial (Art. 3.2.a).</rdfs:comment>
