    <rdfs:label xml:lang="en">Competent technician</rdfs:label>
    <rdfs:comment xml:lang="es">Técnico habilitado para realizar la certificación de eficiencia energética de edificios (Art. 4 bis).</rdfs:comment>
    <rdfs:comment xml:lang="en">Technician qualified to carry out energy performance certification of buildings (Art. 4 bis).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/observedHeritageProtection">
