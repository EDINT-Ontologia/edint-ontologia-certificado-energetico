    <rdfs:comment xml:lang="en">Rating letter shown on the label, according to the rating-letter controlled vocabulary (Art. 15).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/noImprovementJustification">
