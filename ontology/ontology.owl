    <rdfs:comment xml:lang="en">Voluntary authorization or refusal to make name, surname and contact data public (Art. 4 quáter.4, Annex IV).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/CompetentTechnician">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
