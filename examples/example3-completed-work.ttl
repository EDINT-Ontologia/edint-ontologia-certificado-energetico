@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix edintcee: <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> .
@prefix edintceekos-bu: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/building-use/> .
@prefix edintceekos-es: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/energy-source/> .
@prefix edintceekos-cz: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/climatic-zone/> .
@prefix edintceekos-ct: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/certificate-type/> .
@prefix edintceekos-rsv: <http://vocab.linkeddata.es/datosabiertos/kos/edintcee/rating-scale-version/> .
@prefix ex: <http://ejemplo.org/cee/> .

# ---------------------------------------------------------------------------
# EXAMPLE 3: Completed work certificate linked to project predecessor
# Same residential building in Sevilla as example2, after construction.
# Art. 2.c, Art. 9 RD 390/2021 — second phase: certification from the
# effective characteristics of the completed building.
# The building points to the certificate from outside this ontology:
#   <http://ejemplo.org/edificios/bloque_sevilla_avda>
#       ex:hasEnergyCertificate ex:cert_OT_2026_S001 .
# ---------------------------------------------------------------------------

# --- Calculation Procedure (same version as project per Art. 9.4) ---

ex:proc_CEH_2024 a edintcee:CalculationProcedure ;
    edintcee:procedureName "CEH" ;
    edintcee:procedureVersion "2024.1" ;
    edintcee:procedureType "general" .

# --- Competent Technician ---

ex:tech_lnavarro a edintcee:CompetentTechnician ;
    edintcee:technicianName "Laura Navarro Ruiz" ;
    edintcee:technicianNIF "89012345E" ;
    edintcee:technicianQualification "Arquitecta" ;
    edintcee:technicianRegistrationCCAA "Andalucía" ;
    edintcee:technicianPublicAuthorization "true"^^xsd:boolean .

# --- User Recommendations ---

ex:userrec_OT_2026_S001 a edintcee:UserRecommendations ;
    edintcee:userRecommendationsDelivered "true"^^xsd:boolean ;
    edintcee:userRecommendationsDeliveryDate "2026-02-28"^^xsd:date ;
    edintcee:userRecommendationsRecipient "Owner" .

# --- Energy Certificate ---

ex:cert_OT_2026_S001 a edintcee:EnergyCertificate ;
    edintcee:hasRating              ex:rating_OT_2026_S001 ;
    edintcee:issuedBy               ex:tech_lnavarro ;
    edintcee:hasLabel               ex:label_OT_2026_S001 ;
    edintcee:usesProcedure          ex:proc_CEH_2024 ;
    edintcee:hasUserRecommendations ex:userrec_OT_2026_S001 ;
    edintcee:certificateType        edintceekos-ct:CompletedWork ;
    edintcee:predecessorCertificate ex:cert_PROY_2025_S001 ;
    edintcee:usesSameProcedureVersion "true"^^xsd:boolean ;

    # Certificate metadata
    edintcee:certificateNumber      "SE-2026-OT-000001" ;
    edintcee:issueDate              "2026-02-28"^^xsd:date ;
    edintcee:visitDate              "2026-02-20"^^xsd:date ;
    edintcee:registrationDate       "2026-03-05"^^xsd:date ;
    edintcee:validUntil             "2036-02-28"^^xsd:date ;
    edintcee:visitDescription       "Visita in situ: comprobación de ejecución de cerramientos, instalación de aerotermia, solar térmica y fotovoltaica según proyecto." ;
    edintcee:applicableRegulation   "CTE DB-HE (2019), RITE (2021)" ;
    edintcee:registrationCCAA       "Andalucía" ;

    # Observed building data (as built)
    edintcee:observedCadastralRef       "4100901VK1234F0001WX" ;
    edintcee:observedAddress            "Avda. de la Constitución 25" ;
    edintcee:observedMunicipality       "Sevilla" ;
    edintcee:observedProvince           "Sevilla" ;
    edintcee:observedUsefulSurface      "3150.0"^^xsd:decimal ;
    edintcee:observedConstructionYear   "2025"^^xsd:gYear ;
    edintcee:observedBuildingUse        edintceekos-bu:Residential ;
    edintcee:observedClimaticZone       edintceekos-cz:B4 ;
    edintcee:observedHeritageProtection "false"^^xsd:boolean ;
    edintcee:observedIsBuildingPart     "false"^^xsd:boolean ;

    # Envelope (as built — slight variation from project)
    edintcee:envelopeDescription        "Fachada ventilada ejecutada conforme a proyecto. Cubierta invertida con XPS 10 cm. Carpintería PVC con triple acristalamiento, ejecución conforme a EHE." ;
    edintcee:globalHeatTransferCoeff    "0.37"^^xsd:decimal ;
    edintcee:windowAreaRatio            "22.0"^^xsd:decimal ;

    # Systems (as built)
    edintcee:hasHeatingSystem           "true"^^xsd:boolean ;
    edintcee:heatingSystemType          "Bomba de calor aerotermia, suelo radiante" ;
    edintcee:heatingEnergySource        edintceekos-es:Aerothermal ;
    edintcee:heatingEfficiency          "3.78"^^xsd:decimal ;
    edintcee:hasCoolingSystem           "true"^^xsd:boolean ;
    edintcee:coolingSystemType          "Bomba de calor aire-agua, fancoils" ;
    edintcee:coolingEnergySource        edintceekos-es:Aerothermal ;
    edintcee:coolingEfficiency          "3.15"^^xsd:decimal ;
    edintcee:hasDHWSystem               "true"^^xsd:boolean ;
    edintcee:dhwSystemType              "Aerotermia + solar térmico 8 m²" ;
    edintcee:dhwEnergySource            edintceekos-es:Aerothermal ;
    edintcee:hasRenewableGeneration     "true"^^xsd:boolean ;
    edintcee:renewableType              "Solar fotovoltaica 5 kWp" ;
    edintcee:renewableEnergySource      edintceekos-es:SolarPV ;
    edintcee:renewableCapacity          "5.0"^^xsd:decimal ;
    edintcee:hasAutomationSystem        "true"^^xsd:boolean ;
    edintcee:hasMechanicalVentilation   "true"^^xsd:boolean ;
    edintcee:hasHeatRecovery            "true"^^xsd:boolean ;

    # Improvement recommendations (minor, building already high performance)
    edintcee:hasRecommendation           ex:rec_OT_2026_S001_1 .

# --- Energy Rating ---

ex:rating_OT_2026_S001 a edintcee:EnergyRating ;
    edintcee:ratingLetter              "A" ;
    edintcee:ratingScaleVersion        edintceekos-rsv:RD390_2021 ;
    edintcee:primaryEnergyTotal        "30.1"^^xsd:decimal ;
    edintcee:primaryEnergyNonRenewable "13.5"^^xsd:decimal ;
    edintcee:primaryEnergyRenewable    "16.6"^^xsd:decimal ;
    edintcee:co2Emissions              "4.1"^^xsd:decimal ;
    edintcee:heatingDemand             "8.4"^^xsd:decimal ;
    edintcee:coolingDemand             "12.3"^^xsd:decimal ;
    edintcee:dhwDemand                 "9.5"^^xsd:decimal ;
    edintcee:heatingConsumption         "3.6"^^xsd:decimal ;
    edintcee:coolingConsumption         "4.3"^^xsd:decimal ;
    edintcee:dhwConsumption             "3.2"^^xsd:decimal ;
    edintcee:lightingConsumption        "1.6"^^xsd:decimal ;
    edintcee:dataBasis                  "calculated" .

# --- Energy Label ---

ex:label_OT_2026_S001 a edintcee:EnergyLabel ;
    edintcee:labelRatingLetter "A" .

# --- Improvement Recommendation ---

ex:rec_OT_2026_S001_1 a edintcee:ImprovementRecommendation ;
    edintcee:recommendationType        "automation" ;
    edintcee:recommendationDescription "Ampliación del sistema de monitorización energética con contadores individuales por vivienda para optimización del consumo." ;
    edintcee:estimatedSavingPct        "3.0"^^xsd:decimal ;
    edintcee:estimatedSavingKwh        "4500"^^xsd:decimal ;
    edintcee:paybackPeriod             "2.0"^^xsd:decimal ;
    edintcee:estimatedCost             "8000"^^xsd:decimal ;
    edintcee:priority                  1 ;
    edintcee:improvedRatingLetter      "A" .
