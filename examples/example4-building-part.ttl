@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix edintcee: <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> .
@prefix edintceekos-bu: <http://vocab.linkeddata.es/datosabiertos/kos/edint/BuildingUse/> .
@prefix edintceekos-es: <http://vocab.linkeddata.es/datosabiertos/kos/edint/EnergySource/> .
@prefix edintceekos-cz: <http://vocab.linkeddata.es/datosabiertos/kos/edint/ClimaticZone/> .
@prefix edintceekos-ct: <http://vocab.linkeddata.es/datosabiertos/kos/edint/CertificateType/> .
@prefix edintceekos-rl: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RatingLetter/> .
@prefix edintceekos-pt: <http://vocab.linkeddata.es/datosabiertos/kos/edint/ProcedureType/> .
@prefix edintceekos-rt: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RecommendationType/> .
@prefix edintceekos-db: <http://vocab.linkeddata.es/datosabiertos/kos/edint/DataBasis/> .
@prefix edintceekos-rcp: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RecipientType/> .
@prefix edintceekos-rsv: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RatingScaleVersion/> .
@prefix edintceekos-ap: <http://vocab.linkeddata.es/datosabiertos/kos/edint/AccessPath/> .
@prefix edintceekos-cm: <http://vocab.linkeddata.es/datosabiertos/kos/edint/CourseModule/> .
@prefix esdir: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#> .
@prefix esadm: <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#> .
@prefix catastro: <http://vocab.linkeddata.es/datosabiertos/def/catastro/> .
@prefix schema: <http://schema.org/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix ex: <http://ejemplo.org/cee/> .

# ---------------------------------------------------------------------------
# EXAMPLE 4: Part of a building — a commercial premises on ground floor
# Local comercial en Barcelona, zona climática C2, rating F
# ---------------------------------------------------------------------------

# --- Calculation Procedure ---

ex:proc_CEP_s a edintcee:CalculationProcedure ;
    edintcee:procedureName "CEP" ;
    edintcee:procedureVersion "7.0" ;
    edintcee:procedureType edintceekos-pt:Simplified .

# --- Competent Technician ---

ex:tech_cdominguez a edintcee:CompetentTechnician ;
    edintcee:technicianName "Carlos Domínguez Soto" ;
    edintcee:technicianNIF "45678901F" ;
    edintcee:technicianQualification "Ingeniero industrial" ;
    edintcee:technicianRegistrationAutonomousCommunity <http://vocab.linkeddata.es/datosabiertos/recurso/sector-publico/territorio/ComunidadAutonoma/cataluna> ;
    edintcee:technicianAccessPath           edintceekos-ap:UniversityTitleC ;
    edintcee:technicianCourseModules         edintceekos-cm:Module1And2 ;
    edintcee:technicianPublicAuthorization "true"^^xsd:boolean .

# --- User Recommendations ---

ex:userrec_2025_B042 a edintcee:UserRecommendations ;
    edintcee:userRecommendationsDelivered "true"^^xsd:boolean ;
    edintcee:userRecommendationsDeliveryDate "2025-01-22"^^xsd:date ;
    edintcee:userRecommendationsRecipient edintceekos-rcp:Tenant .

# --- Cadastral Property ---

ex:catastro_diagonal420 a catastro:CadastralProperty ;
    catastro:referenceCatastral "0801901VK5678H0001PX" .

# --- Address ---

ex:dir_diagonal420 a esdir:DireccionPostal ;
    schema:streetAddress "Avda. Diagonal 420, local 3" ;
    schema:addressLocality "Barcelona" ;
    schema:addressRegion "Barcelona" ;
    schema:addressCountry "ES" .

# --- Energy Certificate ---

ex:cert_2025_B042 a edintcee:EnergyCertificate ;
    edintcee:hasRating              ex:rating_2025_B042 ;
    edintcee:issuedBy               ex:tech_cdominguez ;
    edintcee:hasLabel               ex:label_2025_B042 ;
    edintcee:usesProcedure          ex:proc_CEP_s ;
    edintcee:hasUserRecommendations ex:userrec_2025_B042 ;
    edintcee:certificateType        edintceekos-ct:ExistingBuilding ;

    # Certificate metadata
    edintcee:certificateNumber              "B-2025-042000" ;
    edintcee:issueDate                      "2025-01-22"^^xsd:date ;
    edintcee:visitDate                      "2025-01-18"^^xsd:date ;
    edintcee:registrationDate               "2025-01-30"^^xsd:date ;
    edintcee:validUntil                     "2035-01-22"^^xsd:date ;
    edintcee:visitDescription               "Visita al local: comprobación de fachada, carpintería, sistema de climatización por splits y alumbrado." ;
    edintcee:applicableRegulation            "CTE DB-HE (2019)" ;
    edintcee:registrationAutonomousCommunity <http://vocab.linkeddata.es/datosabiertos/recurso/sector-publico/territorio/ComunidadAutonoma/cataluna> ;

    # Observed building data — PART of a building
    edintcee:refersToCadastralEntity        ex:catastro_diagonal420 ;
    edintcee:hasObservedAddress             ex:dir_diagonal420 ;
    edintcee:observedBuildingUse            edintceekos-bu:Commercial ;
    edintcee:observedClimaticZone           edintceekos-cz:C2 ;
    edintcee:observedHeritageProtection     "false"^^xsd:boolean ;
    edintcee:observedIsBuildingPart         "true"^^xsd:boolean ;
    edintcee:observedPartDescription        "Local comercial en planta baja de edificio plurifamiliar. Acceso independiente desde calle." ;

    # Envelope
    edintcee:envelopeDescription             "Fachada de ladrillo sin aislar con acabado continuo. Carpintería aluminio sin RPT, acristalamiento sencillo. Cerramiento interior medianería." ;
    edintcee:globalHeatTransferCoeff        [ a qudt:QuantityValue ; qudt:numericValue 3.45 ; qudt:hasUnit qudtu:W-PER-M2-K ] ;
    edintcee:windowAreaRatio                [ a qudt:QuantityValue ; qudt:numericValue 55.0 ; qudt:hasUnit qudtu:PERCENT ] ;

    # Systems
    edintcee:hasHeatingSystem               "true"^^xsd:boolean ;
    edintcee:heatingSystemType              "Split mural aire-aire, 2 unidades" ;
    edintcee:heatingEnergySource            edintceekos-es:Electricity ;
    edintcee:heatingEfficiency              [ a qudt:QuantityValue ; qudt:numericValue 2.80 ; qudt:hasUnit qudtu:PERCENT ] ;
    edintcee:hasCoolingSystem               "true"^^xsd:boolean ;
    edintcee:coolingSystemType              "Split mural aire-aire (mismas unidades)" ;
    edintcee:coolingEnergySource            edintceekos-es:Electricity ;
    edintcee:coolingEfficiency              [ a qudt:QuantityValue ; qudt:numericValue 2.60 ; qudt:hasUnit qudtu:PERCENT ] ;
    edintcee:hasDHWSystem                   "false"^^xsd:boolean ;
    edintcee:hasRenewableGeneration          "false"^^xsd:boolean ;
    edintcee:hasAutomationSystem            "false"^^xsd:boolean ;
    edintcee:hasMechanicalVentilation       "false"^^xsd:boolean ;
    edintcee:hasHeatRecovery                "false"^^xsd:boolean ;
    edintcee:lightingSystemType             "Fluorescente T8" ;
    edintcee:lightingEfficiency              [ a qudt:QuantityValue ; qudt:numericValue 0.55 ; qudt:hasUnit qudtu:LM-PER-W ] ;

    # Improvement recommendations
    edintcee:hasRecommendation              ex:rec_2025_B042_1 ;
    edintcee:hasRecommendation              ex:rec_2025_B042_2 .

# --- Energy Rating ---

ex:rating_2025_B042 a edintcee:EnergyRating ;
    edintcee:ratingLetter              edintceekos-rl:F ;
    edintcee:ratingScaleVersion        edintceekos-rsv:RD390_2021 ;
    edintcee:primaryEnergyTotal        [ a qudt:QuantityValue ; qudt:numericValue 485.0 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:primaryEnergyNonRenewable [ a qudt:QuantityValue ; qudt:numericValue 410.2 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:primaryEnergyRenewable    [ a qudt:QuantityValue ; qudt:numericValue 74.8 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:co2Emissions              [ a qudt:QuantityValue ; qudt:numericValue 95.3 ; qudt:hasUnit qudtu:KiloGM ] ;
    edintcee:heatingDemand             [ a qudt:QuantityValue ; qudt:numericValue 78.5 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:coolingDemand             [ a qudt:QuantityValue ; qudt:numericValue 62.0 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:dhwDemand                 [ a qudt:QuantityValue ; qudt:numericValue 0.0 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:heatingConsumption        [ a qudt:QuantityValue ; qudt:numericValue 82.3 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:coolingConsumption        [ a qudt:QuantityValue ; qudt:numericValue 68.1 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:dhwConsumption            [ a qudt:QuantityValue ; qudt:numericValue 0.0 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:lightingConsumption       [ a qudt:QuantityValue ; qudt:numericValue 24.8 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:dataBasis                 edintceekos-db:Calculated .

# --- Energy Label ---

ex:label_2025_B042 a edintcee:EnergyLabel ;
    edintcee:labelRatingLetter edintceekos-rl:F .

# --- Improvement Recommendations ---

ex:rec_2025_B042_1 a edintcee:ImprovementRecommendation ;
    edintcee:recommendationType        edintceekos-rt:Combined ;
    edintcee:recommendationDescription "Sustituir splits por sistema VRF de alta eficiencia y renovar alumbrado a LED." ;
    edintcee:estimatedSavingPct       [ a qudt:QuantityValue ; qudt:numericValue 42.0 ; qudt:hasUnit qudtu:PERCENT ] ;
    edintcee:estimatedSavingKwh       [ a qudt:QuantityValue ; qudt:numericValue 15200 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:paybackPeriod            [ a qudt:QuantityValue ; qudt:numericValue 5.0 ; qudt:hasUnit qudtu:YEAR ] ;
    edintcee:estimatedCost            [ a qudt:QuantityValue ; qudt:numericValue 28000 ; qudt:hasUnit qudtu:EUR ] ;
    edintcee:priority                 1 ;
    edintcee:improvedRatingLetter     edintceekos-rl:D ;
    edintcee:comfortHealthBenefit     "Mejora del confort térmico y calidad de iluminación." .

ex:rec_2025_B042_2 a edintcee:ImprovementRecommendation ;
    edintcee:recommendationType        edintceekos-rt:Envelope ;
    edintcee:recommendationDescription "Aislamiento interior de fachada con panel sándwich 4 cm y sustitución de carpintería por PVC con doble acristalamiento." ;
    edintcee:estimatedSavingPct       [ a qudt:QuantityValue ; qudt:numericValue 30.0 ; qudt:hasUnit qudtu:PERCENT ] ;
    edintcee:estimatedSavingKwh       [ a qudt:QuantityValue ; qudt:numericValue 10800 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:paybackPeriod            [ a qudt:QuantityValue ; qudt:numericValue 8.0 ; qudt:hasUnit qudtu:YEAR ] ;
    edintcee:estimatedCost            [ a qudt:QuantityValue ; qudt:numericValue 35000 ; qudt:hasUnit qudtu:EUR ] ;
    edintcee:priority                 2 ;
    edintcee:improvedRatingLetter     edintceekos-rl:D .
