@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix edintcee: <http://vocab.linkeddata.es/datosabiertos/def/sectorpublico/cee/> .
@prefix edintceekos-bu: <http://vocab.linkeddata.es/datosabiertos/kos/edint/BuildingUse/> .
@prefix edintceekos-es: <http://vocab.linkeddata.es/datosabiertos/kos/edint/EnergySource/> .
@prefix edintceekos-cz: <http://vocab.linkeddata.es/datosabiertos/kos/edint/ClimaticZone/> .
@prefix edintceekos-ct: <http://vocab.linkeddata.es/datosabiertos/kos/edint/CertificateType/> .
@prefix edintceekos-rl: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RatingLetter/> .
@prefix edintceekos-pt: <http://vocab.linkeddata.es/datosabiertos/kos/edint/ProcedureType/> .
@prefix edintceekos-rt: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RecommendationType/> .
@prefix edintceekos-db: <http://vocab.linkeddata.es/datosabiertos/kos/edint/DataBasis/> .
@prefix edintceekos-rcp: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RecipientType/> .
@prefix edintceekos-rsv: <http://vocab.linkeddata.es/datosabiertos/kos/edint/RatingScaleVersion/> .
@prefix esdir: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#> .
@prefix esadm: <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#> .
@prefix catastro: <http://vocab.linkeddata.es/datosabiertos/def/catastro/> .
@prefix schema: <http://schema.org/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix ex: <http://ejemplo.org/cee/> .

# ---------------------------------------------------------------------------
# EXAMPLE 1: Existing building certificate
# Residential block in Madrid, built 2005, rating D
# ---------------------------------------------------------------------------

# --- Calculation Procedure ---

ex:proc_CEP a edintcee:CalculationProcedure ;
    edintcee:procedureName "CEP" ;
    edintcee:procedureVersion "7.0" ;
    edintcee:procedureType edintceekos-pt:General .

# --- Competent Technician ---

ex:tech_mlopez a edintcee:CompetentTechnician ;
    edintcee:technicianName "María López García" ;
    edintcee:technicianNIF "23456789B" ;
    edintcee:technicianQualification "Arquitecta" ;
    edintcee:technicianRegistrationAutonomousCommunity <http://vocab.linkeddata.es/datosabiertos/recurso/sector-publico/territorio/ComunidadAutonoma/madrid> ;
    edintcee:hasTechnicianAddress ex:dir_tech_mlopez ;
    edintcee:technicianEmail "m.lopez@ejemplo.es" ;
    edintcee:technicianPhone "+34-91-123-4567" ;
    edintcee:technicianPublicAuthorization "true"^^xsd:boolean .

ex:dir_tech_mlopez a esdir:DireccionPostal ;
    schema:streetAddress "Calle de O'Donnell 25, 3ºA" ;
    schema:addressLocality "Madrid" ;
    schema:addressRegion "Madrid" ;
    schema:postalCode "28009" ;
    schema:addressCountry "ES" .

# --- User Recommendations ---

ex:userrec_2024_M12345 a edintcee:UserRecommendations ;
    edintcee:userRecommendationsDelivered "true"^^xsd:boolean ;
    edintcee:userRecommendationsDeliveryDate "2024-05-20"^^xsd:date ;
    edintcee:userRecommendationsRecipient edintceekos-rcp:Owner .

# --- Cadastral Property ---

ex:catastro_mayor10 a catastro:CadastralProperty ;
    catastro:referenceCatastral "2807901VK4717F0001WX" .

# --- Address ---

ex:dir_mayor10 a esdir:DireccionPostal ;
    schema:streetAddress "Calle Mayor 10" ;
    schema:addressLocality "Madrid" ;
    schema:addressRegion "Madrid" ;
    schema:addressCountry "ES" .

# --- Energy Certificate ---

ex:cert_2024_M12345 a edintcee:EnergyCertificate ;
    edintcee:hasRating              ex:rating_2024_M12345 ;
    edintcee:issuedBy               ex:tech_mlopez ;
    edintcee:hasLabel               ex:label_2024_M12345 ;
    edintcee:usesProcedure          ex:proc_CEP ;
    edintcee:hasUserRecommendations ex:userrec_2024_M12345 ;
    edintcee:certificateType        edintceekos-ct:ExistingBuilding ;
    edintcee:predecessorCertificate ex:cert_2016_M12345 ;

    # Certificate metadata
    edintcee:certificateNumber              "M-2024-012345" ;
    edintcee:issueDate                      "2024-05-20"^^xsd:date ;
    edintcee:visitDate                      "2024-05-15"^^xsd:date ;
    edintcee:registrationDate               "2024-05-28"^^xsd:date ;
    edintcee:validUntil                     "2034-05-20"^^xsd:date ;
    edintcee:visitDescription               "Visita in situ: comprobación de cerramientos de fachada, cubierta, carpintería exterior. Verificación de caldera mural de gas natural en vivienda tipo." ;
    edintcee:applicableRegulation            "CTE DB-HE (2006), RITE (2007)" ;
    edintcee:registrationAutonomousCommunity <http://vocab.linkeddata.es/datosabiertos/recurso/sector-publico/territorio/ComunidadAutonoma/madrid> ;

    # Observed building data
    edintcee:refersToCadastralEntity        ex:catastro_mayor10 ;
    edintcee:hasObservedAddress             ex:dir_mayor10 ;
    edintcee:observedBuildingUse            edintceekos-bu:Residential ;
    edintcee:observedClimaticZone           edintceekos-cz:D3 ;
    edintcee:observedHeritageProtection     "false"^^xsd:boolean ;
    edintcee:observedIsBuildingPart         "false"^^xsd:boolean ;

    # Envelope
    edintcee:envelopeDescription            "Fachada de ladrillo cara vista con cámara de aire de 5 cm sin aislar. Cubierta plana transitable. Carpintería aluminio RPT, doble acristalamiento (6/12/6)." ;
    edintcee:globalHeatTransferCoeff        [ a qudt:QuantityValue ; qudt:numericValue 1.92 ; qudt:hasUnit qudtu:W-PER-M2-K ] ;
    edintcee:windowAreaRatio                [ a qudt:QuantityValue ; qudt:numericValue 28.0 ; qudt:hasUnit qudtu:PERCENT ] ;

    # Systems
    edintcee:hasHeatingSystem               "true"^^xsd:boolean ;
    edintcee:heatingSystemType              "Caldera mural condensación gas natural, radiadores" ;
    edintcee:heatingEnergySource            edintceekos-es:NaturalGas ;
    edintcee:heatingEfficiency              [ a qudt:QuantityValue ; qudt:numericValue 0.92 ; qudt:hasUnit qudtu:PERCENT ] ;
    edintcee:hasCoolingSystem               "false"^^xsd:boolean ;
    edintcee:hasDHWSystem                   "true"^^xsd:boolean ;
    edintcee:dhwSystemType                  "Caldera mural gas natural, acumulador 80L" ;
    edintcee:dhwEnergySource                edintceekos-es:NaturalGas ;
    edintcee:hasRenewableGeneration          "false"^^xsd:boolean ;
    edintcee:hasAutomationSystem            "false"^^xsd:boolean ;
    edintcee:hasMechanicalVentilation       "false"^^xsd:boolean ;
    edintcee:hasHeatRecovery                "false"^^xsd:boolean ;

    # Improvement recommendations
    edintcee:hasRecommendation              ex:rec_2024_M12345_1 ;
    edintcee:hasRecommendation              ex:rec_2024_M12345_2 ;
    edintcee:hasRecommendation              ex:rec_2024_M12345_3 .

# --- Energy Rating ---

ex:rating_2024_M12345 a edintcee:EnergyRating ;
    edintcee:ratingLetter              edintceekos-rl:D ;
    edintcee:ratingScaleVersion        edintceekos-rsv:RD390_2021 ;
    edintcee:primaryEnergyTotal        [ a qudt:QuantityValue ; qudt:numericValue 152.4 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:primaryEnergyNonRenewable [ a qudt:QuantityValue ; qudt:numericValue 112.8 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:primaryEnergyRenewable    [ a qudt:QuantityValue ; qudt:numericValue 39.6 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:co2Emissions              [ a qudt:QuantityValue ; qudt:numericValue 34.2 ; qudt:hasUnit qudtu:KiloGM ] ;
    edintcee:heatingDemand             [ a qudt:QuantityValue ; qudt:numericValue 52.1 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:coolingDemand             [ a qudt:QuantityValue ; qudt:numericValue 16.8 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:dhwDemand                 [ a qudt:QuantityValue ; qudt:numericValue 18.3 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:heatingConsumption        [ a qudt:QuantityValue ; qudt:numericValue 56.7 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:coolingConsumption        [ a qudt:QuantityValue ; qudt:numericValue 19.4 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:dhwConsumption            [ a qudt:QuantityValue ; qudt:numericValue 23.1 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:lightingConsumption       [ a qudt:QuantityValue ; qudt:numericValue 5.2 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:dataBasis                 edintceekos-db:Calculated .

# --- Energy Label ---

ex:label_2024_M12345 a edintcee:EnergyLabel ;
    edintcee:labelRatingLetter edintceekos-rl:D .

# --- Improvement Recommendations ---

ex:rec_2024_M12345_1 a edintcee:ImprovementRecommendation ;
    edintcee:recommendationType        edintceekos-rt:Installation ;
    edintcee:recommendationDescription "Sustituir calderas individuales por sistema centralizado de aerotermia con bomba de calor aire-agua." ;
    edintcee:estimatedSavingPct       [ a qudt:QuantityValue ; qudt:numericValue 38.0 ; qudt:hasUnit qudtu:PERCENT ] ;
    edintcee:estimatedSavingKwh       [ a qudt:QuantityValue ; qudt:numericValue 43200 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:paybackPeriod            [ a qudt:QuantityValue ; qudt:numericValue 9.5 ; qudt:hasUnit qudtu:YEAR ] ;
    edintcee:estimatedCost            [ a qudt:QuantityValue ; qudt:numericValue 185000 ; qudt:hasUnit qudtu:EUR ] ;
    edintcee:priority                 1 ;
    edintcee:improvedRatingLetter     edintceekos-rl:B ;
    edintcee:comfortHealthBenefit     "Mayor confort térmico en invierno y posibilidad de refrigeración en verano." .

ex:rec_2024_M12345_2 a edintcee:ImprovementRecommendation ;
    edintcee:recommendationType        edintceekos-rt:Envelope ;
    edintcee:recommendationDescription "Aislamiento exterior SATE 8 cm lana de roca. Cubierta 10 cm poliuretano proyectado." ;
    edintcee:estimatedSavingPct       [ a qudt:QuantityValue ; qudt:numericValue 25.0 ; qudt:hasUnit qudtu:PERCENT ] ;
    edintcee:estimatedSavingKwh       [ a qudt:QuantityValue ; qudt:numericValue 28400 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:paybackPeriod            [ a qudt:QuantityValue ; qudt:numericValue 14.0 ; qudt:hasUnit qudtu:YEAR ] ;
    edintcee:estimatedCost            [ a qudt:QuantityValue ; qudt:numericValue 210000 ; qudt:hasUnit qudtu:EUR ] ;
    edintcee:priority                 2 ;
    edintcee:improvedRatingLetter     edintceekos-rl:B .

ex:rec_2024_M12345_3 a edintcee:ImprovementRecommendation ;
    edintcee:recommendationType        edintceekos-rt:Automation ;
    edintcee:recommendationDescription "Sistema de control centralizado con termostatos programables y válvulas termostáticas." ;
    edintcee:estimatedSavingPct       [ a qudt:QuantityValue ; qudt:numericValue 8.0 ; qudt:hasUnit qudtu:PERCENT ] ;
    edintcee:estimatedSavingKwh       [ a qudt:QuantityValue ; qudt:numericValue 9100 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:paybackPeriod            [ a qudt:QuantityValue ; qudt:numericValue 3.5 ; qudt:hasUnit qudtu:YEAR ] ;
    edintcee:estimatedCost            [ a qudt:QuantityValue ; qudt:numericValue 18000 ; qudt:hasUnit qudtu:EUR ] ;
    edintcee:priority                 3 ;
    edintcee:improvedRatingLetter     edintceekos-rl:C .

# --- Predecessor Certificate ---

ex:cert_2016_M12345 a edintcee:EnergyCertificate ;
    edintcee:hasRating        ex:rating_2016_M12345 ;
    edintcee:issuedBy         ex:tech_jperez ;
    edintcee:usesProcedure    ex:proc_CEP_old ;
    edintcee:hasUserRecommendations ex:userrec_2016_M12345 ;
    edintcee:certificateNumber "M-2016-007890" ;
    edintcee:issueDate        "2016-09-12"^^xsd:date ;
    edintcee:validUntil       "2026-09-12"^^xsd:date ;
    edintcee:refersToCadastralEntity ex:catastro_mayor10 ;
    edintcee:certificateType  edintceekos-ct:ExistingBuilding .

ex:rating_2016_M12345 a edintcee:EnergyRating ;
    edintcee:ratingLetter              edintceekos-rl:E ;
    edintcee:ratingScaleVersion        edintceekos-rsv:RD390_2021 ;
    edintcee:primaryEnergyNonRenewable [ a qudt:QuantityValue ; qudt:numericValue 148.5 ; qudt:hasUnit qudtu:KiloW-HR ] ;
    edintcee:co2Emissions              [ a qudt:QuantityValue ; qudt:numericValue 45.1 ; qudt:hasUnit qudtu:KiloGM ] .

ex:tech_jperez a edintcee:CompetentTechnician ;
    edintcee:technicianName "Juan Pérez Martínez" ;
    edintcee:technicianNIF "34567890C" ;
    edintcee:technicianQualification "Arquitecto técnico" ;
    edintcee:technicianRegistrationAutonomousCommunity <http://vocab.linkeddata.es/datosabiertos/recurso/sector-publico/territorio/ComunidadAutonoma/madrid> .

ex:proc_CEP_old a edintcee:CalculationProcedure ;
    edintcee:procedureName "CEP" ;
    edintcee:procedureVersion "5.2" ;
    edintcee:procedureType edintceekos-pt:General .

ex:userrec_2016_M12345 a edintcee:UserRecommendations ;
    edintcee:userRecommendationsDelivered "true"^^xsd:boolean .
